{
  "Logging": {
    "Path": "Logs/log.txt",
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "Bots": {
    "Active": "Telegram",
    "Telegram": {
      "ApiToken": "YOUR_TELEGRAM_API_TOKEN"
    },
    "Discord": {
      "ApiToken": ""
    }
  },
  "AiAgent": {
    "Provider": "Gemini",
    "ApiKey": "YOUR_GEMINI_API_KEY",
    "Model": "gemini-2.5-flash"
  },
  "Tools": [
    {
      "Name": "GetWeather",
      "Description": "Получить текущую погоду по городу",
      "Parameters": {
        "City": "Moscow"
      }
    },
    {
      "Name": "SaveNote",
      "Description": "Сохранить заметку пользователя",
      "Parameters": {
        "Note": ""
      }
    }
  ]
}
